{
  "name": "blueprint-map",
  "version": "1.0.0",
  "private": true,
  "scripts": {
    "test": "node test/parser.test.js",
    "test:regression": "node test/regression/run-offline.js",
    "test:regression:logged": "node test/regression/run-offline.js && node scripts/regression-to-memory.mjs",
    "test:auth-gate": "node test/auth-gate.test.js",
    "test:baseline": "node test/check-baseline.js",
    "test:smoke": "node test/smoke.playwright.js",
    "test:perf": "node test/perf-measure.js",
    "test:audit-sites": "node test/audit-sites.mjs",
    "test:audit-sites:update": "node test/audit-sites.mjs --update-baseline",
    "baseline:capture": "node test/regression/run-offline.js && node test/capture-baseline.js",
    "test:all": "npm run test && npm run test:regression && npm run test:baseline && npm run test:smoke && npm run test:perf",
    "apps:push": "cd appsscript && clasp push -f",
    "apps:deploy": "cd appsscript && clasp push -f && clasp deploy -i AKfycbw_DYXJFneaL7C-6xP4L2XxvlJN9wm0sIEZZWC_aDEygfj5vFUPk98iDV4oUy8r45Bt -d \"$(git log -1 --pretty=%s)\""
  },
  "devDependencies": {
    "playwright": "^1.59.1"
  }
}
